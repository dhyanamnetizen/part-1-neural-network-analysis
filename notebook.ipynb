import os
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import confusion_matrix, classification_report

import tensorflow as tf
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense
from tensorflow.keras.optimizers import Adam

# -------------------------------------------------------------
# TASK 1 & 2: DATASET UNDERSTANDING & PREPROCESSING
# -------------------------------------------------------------

# Load dataset
df = pd.read_csv('customer_churn_nn.csv')

# Basic check
print(f"Dataset Shape: {df.shape}")
print("\nMissing Values Count:")
print(df.isnull().sum())

print("\nTarget Variable Distribution:")
print(df['churn'].value_counts())
print(df['churn'].value_counts(normalize=True))

# Separate features and target (dropping identifier)
X = df.drop(columns=['customer_id', 'churn'])
y = df['churn']

# Encode categorical variables using One-Hot Encoding
categorical_cols = ['region', 'plan_type', 'contract_type', 'payment_method']
X_encoded = pd.get_dummies(X, columns=categorical_cols, drop_first=True)

# Stratified split to ensure both sets contain churn instances
X_train, X_test, y_train, y_test = train_test_split(
    X_encoded, y, test_size=0.2, stratify=y, random_state=42
)

# Convert boolean columns to floats for TensorFlow compatibility
X_train = X_train.astype(float)
X_test = X_test.astype(float)

# Scale continuous numerical features
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)

# Create results directory if it doesn't exist
os.makedirs('results', exist_ok=True)


# -------------------------------------------------------------
# TASK 3, 4 & 5: NN MODEL BUILDING & EXPERIMENTATION
# -------------------------------------------------------------

def build_experiment_1(input_dim):
    # Baseline: Single hidden layer, small capacity
    model = Sequential([
        Dense(16, activation='relu', input_dim=input_dim),
        Dense(1, activation='sigmoid')
    ])
    return model

def build_experiment_2(input_dim):
    # Deeper/Wider network with higher learning rate
    model = Sequential([
        Dense(32, activation='relu', input_dim=input_dim),
        Dense(16, activation='relu'),
        Dense(1, activation='sigmoid')
    ])
    return model

def build_experiment_3(input_dim):
    # Tanh activation, smaller learning rate, smaller batch size
    model = Sequential([
        Dense(16, activation='tanh', input_dim=input_dim),
        Dense(1, activation='sigmoid')
    ])
    return model

# Setup reproduction seeds
np.random.seed(42)
tf.random.set_seed(42)

input_dimension = X_train_scaled.shape[1]
experiments_data = []

# --- Run Experiment 1 ---
model1 = build_experiment_1(input_dimension)
model1.compile(optimizer=Adam(learning_rate=0.001), loss='binary_crossentropy', metrics=['accuracy'])
history1 = model1.fit(X_train_scaled, y_train, validation_data=(X_test_scaled, y_test), batch_size=32, epochs=20, verbose=0)
loss_tr1, acc_tr1 = model1.evaluate(X_train_scaled, y_train, verbose=0)
loss_te1, acc_te1 = model1.evaluate(X_test_scaled, y_test, verbose=0)
preds1 = (model1.predict(X_test_scaled) > 0.5).astype(int).flatten()
cm1 = confusion_matrix(y_test, preds1)

experiments_data.append({
    'Experiment': 'Exp 1: Baseline (16 Nodes, ReLU)',
    'Train Loss': round(loss_tr1, 4), 'Train Accuracy': round(acc_tr1, 4),
    'Test Loss': round(loss_te1, 4), 'Test Accuracy': round(acc_te1, 4),
    'False Positives': cm1[0, 1], 'True Positives': cm1[1, 1]
})

# --- Run Experiment 2 ---
model2 = build_experiment_2(input_dimension)
model2.compile(optimizer=Adam(learning_rate=0.005), loss='binary_crossentropy', metrics=['accuracy'])
history2 = model2.fit(X_train_scaled, y_train, validation_data=(X_test_scaled, y_test), batch_size=64, epochs=30, verbose=0)
loss_tr2, acc_tr2 = model2.evaluate(X_train_scaled, y_train, verbose=0)
loss_te2, acc_te2 = model2.evaluate(X_test_scaled, y_test, verbose=0)
preds2 = (model2.predict(X_test_scaled) > 0.5).astype(int).flatten()
cm2 = confusion_matrix(y_test, preds2)

experiments_data.append({
    'Experiment': 'Exp 2: Deeper (32->16 Nodes, High LR)',
    'Train Loss': round(loss_tr2, 4), 'Train Accuracy': round(acc_tr2, 4),
    'Test Loss': round(loss_te2, 4), 'Test Accuracy': round(acc_te2, 4),
    'False Positives': cm2[0, 1], 'True Positives': cm2[1, 1]
})

# --- Run Experiment 3 ---
model3 = build_experiment_3(input_dimension)
model3.compile(optimizer=Adam(learning_rate=0.0005), loss='binary_crossentropy', metrics=['accuracy'])
history3 = model3.fit(X_train_scaled, y_train, validation_data=(X_test_scaled, y_test), batch_size=16, epochs=15, verbose=0)
loss_tr3, acc_tr3 = model3.evaluate(X_train_scaled, y_train, verbose=0)
loss_te3, acc_te3 = model3.evaluate(X_test_scaled, y_test, verbose=0)
preds3 = (model3.predict(X_test_scaled) > 0.5).astype(int).flatten()
cm3 = confusion_matrix(y_test, preds3)

experiments_data.append({
    'Experiment': 'Exp 3: Alternative (16 Nodes, Tanh, Low LR)',
    'Train Loss': round(loss_tr3, 4), 'Train Accuracy': round(acc_tr3, 4),
    'Test Loss': round(loss_te3, 4), 'Test Accuracy': round(acc_te3, 4),
    'False Positives': cm3[0, 1], 'True Positives': cm3[1, 1]
})

# Compile and export comparison data
comparison_df = pd.DataFrame(experiments_data)
comparison_df.to_csv('results/model_comparison_table.csv', index=False)
print("\n--- Hyperparameter Experimentation Results ---")
print(comparison_df.to_string(index=False))


# -------------------------------------------------------------
# VISUALIZE EVALUATION OUTPUTS
# -------------------------------------------------------------

fig, axes = plt.subplots(2, 2, figsize=(14, 10))

# Plot training loss tracking curves
axes[0, 0].plot(history1.history['loss'], label='Exp 1 Train Loss', color='blue')
axes[0, 0].plot(history1.history['val_loss'], label='Exp 1 Val Loss', linestyle='--', color='darkblue')
axes[0, 0].plot(history2.history['loss'], label='Exp 2 Train Loss', color='orange')
axes[0, 0].plot(history2.history['val_loss'], label='Exp 2 Val Loss', linestyle='--', color='darkorange')
axes[0, 0].set_title('Training vs Validation Loss Trajectory')
axes[0, 0].set_xlabel('Epochs')
axes[0, 0].set_ylabel('Loss')
axes[0, 0].legend()
axes[0, 0].grid(True)

# Confusion Matrix Visualizations
sns.heatmap(cm1, annot=True, fmt='d', cmap='Blues', ax=axes[0, 1], cbar=False)
axes[0, 1].set_title('Exp 1 Confusion Matrix')
axes[0, 1].set_xlabel('Predicted Classes')
axes[0, 1].set_ylabel('True Classes')

sns.heatmap(cm2, annot=True, fmt='d', cmap='Oranges', ax=axes[1, 0], cbar=False)
axes[1, 0].set_title('Exp 2 Confusion Matrix')
axes[1, 0].set_xlabel('Predicted Classes')
axes[1, 0].set_ylabel('True Classes')

sns.heatmap(cm3, annot=True, fmt='d', cmap='Greens', ax=axes[1, 1], cbar=False)
axes[1, 1].set_title('Exp 3 Confusion Matrix')
axes[1, 1].set_xlabel('Predicted Classes')
axes[1, 1].set_ylabel('True Classes')

plt.tight_layout()
plt.savefig('results/evaluation_outputs.png', dpi=300)
plt.show()
